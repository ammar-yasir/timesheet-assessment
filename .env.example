# next-auth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key_here_run_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Database (for future use with real database)
DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# API Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: JWT configuration
JWT_SECRET=your_jwt_secret_here

# Note: In production, use environment-specific variables
# - .env.local (localhost, dev)
# - .env.production (deployed)
